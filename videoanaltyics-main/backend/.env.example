# Backend Configuration
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://analytics:analytics_password@localhost:5432/video_analytics
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_DETECTIONS=video_detections
KAFKA_TOPIC_EVENTS=video_events
KAFKA_TOPIC_ALERTS=video_alerts
KAFKA_CONSUMER_GROUP=video-analytics-group
KAFKA_BATCH_SIZE=100

# YOLOv8 Configuration
YOLO_MODEL_SIZE=m
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_DEVICE=cpu
YOLO_INFERENCE_TIMEOUT=5

# Video Processing
FRAME_SKIP=2
BUFFER_SIZE=30
OUTPUT_FPS=15
VIDEO_RESOLUTION_WIDTH=1280
VIDEO_RESOLUTION_HEIGHT=720

# Event Detection
ENABLE_CROWD_DETECTION=True
CROWD_THRESHOLD=10
ENABLE_INTRUSION_DETECTION=True

# Alerting
ALERT_COOLDOWN_SECONDS=30
ALERT_CONFIDENCE_THRESHOLD=0.6

# Privacy
ENABLE_FACE_BLUR=True
BLUR_STRENGTH=25

# Monitoring
ENABLE_METRICS=True
METRICS_PORT=9090
